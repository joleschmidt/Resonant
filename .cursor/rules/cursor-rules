### API Patterns (Required)
```typescript
// ALWAYS use this pattern for API calls
const useApiCall = () => {
  return useQuery({
    queryKey: ['key'],
    queryFn: async () => {
      const { data, error } = await supabase
        .from('table')
        .select('*');
      
      if (error) throw error;
      return data;
    },
    staleTime: 5 * 60 * 1000,
  });
};
```

