          },
          {
            name: 'get_price_analysis',
            description: 'Get detailed price analysis for a specific guitar',
            inputSchema: {
              type: 'object',
              required: ['brand'],
              properties: {
                brand: {
                  type: 'string',
                  description: 'Guitar brand',
                },
                model: {
                  type: 'string',
