  // Resource implementations
  private async getActiveListings() {
    const { data, error } = await this.supabase
      .from('guitar_listings')
      .select(`
        id, title, brand, model, guitar_type, condition, price, 
        location_city, created_at, views, favorites_count,
        profiles!seller_id (username, verification_status, seller_rating)
      `)
      .eq('status', 'active')
      .order('created_at', { ascending: false })
      .limit(50);

    if (error) throw new McpError(ErrorCode.InternalError, error.message);

    return {
      contents: [
        {
          uri: 'marketplace://listings/active',
          mimeType: 'application/json',
          text: JSON.stringify({
            listings: data,
            total_count: data?.length || 0,
            last_updated: new Date().toISOString(),
          }, null, 2),
        },
      ],
    };
  }

  private async getAnalyticsDashboard() {
    const [listingsResult, usersResult, transactionsResult] = await Promise.all([
      this.supabase
        .from('guitar_listings')
        .select('*', { count: 'exact', head: true })
        .eq('status', 'active'),
      this.supabase
        .from('profiles')
        .select('*', { count: 'exact', head: true }),
      this.supabase
        .from('transactions')
        .select('amount, created_at')
        .gte('created_at', new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString()),
    ]);

    const totalRevenue = transactionsResult.data?.reduce(
      (sum, t) => sum + (t.amount || 0), 0
    ) || 0;

    return {
      contents: [
        {
          uri: 'marketplace://analytics/dashboard',
          mimeType: 'application/json',
          text: JSON.stringify({
            active_listings: listingsResult.count || 0,
            total_users: usersResult.count || 0,
            monthly_revenue: totalRevenue,
            transactions_count: transactionsResult.data?.length || 0,
            timestamp: new Date().toISOString(),
          }, null, 2),
        },
      ],
    };
  }

  private async getGuitarTrends() {
    const { data, error } = await this.supabase
      .from('guitar_listings')
      .select('brand, guitar_type, price, created_at, views')
      .eq('status', 'active')
      .gte('created_at', new Date(Date.now() - 30 * 24 * 60 * 60 * 1000).toISOString());

    if (error) throw new McpError(ErrorCode.InternalError, error.message);

    // Process trends data
    const brandCounts = data?.reduce((acc, listing) => {
      acc[listing.brand] = (acc[listing.brand] || 0) + 1;
      return acc;
    }, {} as Record<string, number>) || {};

    const typeCounts = data?.reduce((acc, listing) => {
      acc[listing.guitar_type] = (acc[listing.guitar_type] || 0) + 1;
      return acc;
    }, {} as Record<string, number>) || {};

    const averagePrices = data?.reduce((acc, listing) => {
      if (!acc[listing.brand]) {
        acc[listing.brand] = { total: 0, count: 0 };
      }
      acc[listing.brand].total += listing.price;
      acc[listing.brand].count += 1;
      return acc;
    }, {} as Record<string, { total: number; count: number }>) || {};

    // Calculate average prices
    const avgPrices = Object.entries(averagePrices).reduce((acc, [brand, data]) => {
      acc[brand] = Math.round(data.total / data.count);
      return acc;
    }, {} as Record<string, number>);

    return {
      contents: [
        {
          uri: 'marketplace://trends/guitars',
          mimeType: 'application/json',
          text: JSON.stringify({
            trending_brands: Object.entries(brandCounts)
              .sort(([,a], [,b]) => b - a)
              .slice(0, 10),
            guitar_types: typeCounts,
            average_prices: avgPrices,
            total_listings: data?.length || 0,
            analysis_period: '30 days',
            timestamp: new Date().toISOString(),
          }, null, 2),
        },
      ],
    };
  }

  private async getUserStatistics() {
    const { data, error } = await this.supabase
      .from('profiles')
      .select('verification_status, account_type, created_at, seller_rating');

    if (error) throw new McpError(ErrorCode.InternalError, error.message);

    const verificationStats = data?.reduce((acc, user) => {
      acc[user.verification_status] = (acc[user.verification_status] || 0) + 1;
      return acc;
    }, {} as Record<string, number>) || {};

    const accountTypeStats = data?.reduce((acc, user) => {
      acc[user.account_type] = (acc[user.account_type] || 0) + 1;
      return acc;
    }, {} as Record<string, number>) || {};

    return {
      contents: [
        {
          uri: 'marketplace://users/statistics',
          mimeType: 'application/json',
          text: JSON.stringify({
            total_users: data?.length || 0,
            verification_breakdown: verificationStats,
            account_types: accountTypeStats,
            average_seller_rating: data?.reduce((sum, user) => sum + (user.seller_rating || 0), 0) / (data?.length || 1),
            timestamp: new Date().toISOString(),
          }, null, 2),
        },
      ],
    };
  }

  private async getSecurityAlerts() {
    const { data, error } = await this.supabase
      .from('reported_content')
      .select(`
        id, content_type, reason, status, created_at,
        profiles!reporter_id (username)
      `)
      .eq('status', 'pending')
      .order('created_at', { ascending: false })
      .limit(20);

    if (error) throw new McpError(ErrorCode.InternalError, error.message);

    return {
      contents: [
        {
          uri: 'marketplace://security/alerts',
          mimeType: 'application/json',
          text: JSON.stringify({
            pending_reports: data || [],
            total_pending: data?.length || 0,
            timestamp: new Date().toISOString(),
          }, null, 2),
        },
      ],
    };
  }

  // Tool implementations
  private async searchGuitars(params: z.infer<typeof SearchParamsSchema>) {
    let query = this.supabase
      .from('guitar_listings')
      .select(`
        id, title, brand, model, guitar_type, condition, price,
        location_city, created_at, images, views,
        profiles!seller_id (username, verification_status, seller_rating)
      `)
      .eq('status', 'active');

    // Apply filters
    if (params.query) {
      query = query.textSearch('search_vector', params.query);
    }
    if (params.brand) {
      query = query.eq('brand', params.brand);
    }
    if (params.guitar_type) {
      query = query.eq('guitar_type', params.guitar_type);
    }
    if (params.condition) {
      query = query.eq('condition', params.condition);
    }
    if (params.price_min) {
      query = query.gte('price', params.price_min);
    }
    if (params.price_max) {
      query = query.lte('price', params.price_max);
    }
    if (params.location) {
      query = query.ilike('location_city', `%${params.location}%`);
    }

    query = query.order('created_at', { ascending: false }).limit(params.limit);

    const { data, error } = await query;

    if (error) throw new McpError(ErrorCode.InternalError, error.message);

    return {
      content: [
        {
          type: 'text',
          text: JSON.stringify({
            results: data,
            count: data?.length || 0,
            search_params: params,
            timestamp: new Date().toISOString(),
          }, null, 2),
        },
      ],
    };
  }

  private async analyzeMarketTrends(params: z.infer<typeof AnalysisParamsSchema>) {
    const timeMap = { '24h': 1, '7d': 7, '30d': 30, '90d': 90 };
    const days = timeMap[params.timeframe];
    const startDate = new Date(Date.now() - days * 24 * 60 * 60 * 1000);

    let query = this.supabase
      .from('guitar_listings')
      .select('brand, guitar_type, price, condition, created_at, views')
      .eq('status', 'active')
      .gte('created_at', startDate.toISOString());

    if (params.category) {
      query = query.eq('guitar_type', params.category);
    }
    if (params.brand) {
      query = query.eq('brand', params.brand);
    }

    const { data, error } = await query;

    if (error) throw new McpError(ErrorCode.InternalError, error.message);

    // Analyze trends
    const analysis = {
      total_listings: data?.length || 0,
      average_price: data?.reduce((sum, item) => sum + item.price, 0) / (data?.length || 1),
      price_trend: this.calculatePriceTrend(data || []),
      most_popular_brand: this.getMostPopular(data?.map(item => item.brand) || []),
      condition_distribution: this.getDistribution(data?.map(item => item.condition) || []),
      timeframe: params.timeframe,
    };

    return {
      content: [
        {
          type: 'text',
          text: JSON.stringify(analysis, null, 2),
        },
      ],
    };
  }

  private async getPriceAnalysis(params: z.infer<typeof PriceAnalysisSchema>) {
    let query = this.supabase
      .from('guitar_listings')
      .select('price, condition, year, created_at, status')
      .eq('brand', params.brand)
      .eq('status', 'active');

    if (params.model) {
      query = query.eq('model', params.model);
    }
    if (params.year) {
      query = query.eq('year', params.year);
    }
    if (params.condition) {
      query = query.eq('condition', params.condition);
    }

    const { data, error } = await query;

    if (error) throw new McpError(ErrorCode.InternalError, error.message);

    if (!data || data.length === 0) {
      return {
        content: [
          {
            type: 'text',
            text: 'No matching guitars found for price analysis.',
          },
        ],
      };
    }

    const prices = data.map(item => item.price).sort((a, b) => a - b);
    const analysis = {
      sample_size: prices.length,
      min_price: Math.min(...prices),
      max_price: Math.max(...prices),
      average_price: prices.reduce((sum, price) => sum + price, 0) / prices.length,
      median_price: prices[Math.floor(prices.length / 2)],
      price_distribution: this.getPriceDistribution(prices),
      market_position: this.getMarketPosition(prices),
    };

    return {
      content: [
        {
          type: 'text',
          text: JSON.stringify(analysis, null, 2),
        },
      ],
    };
  }

  private async moderateContent(params: { content: string; content_type?: string }) {
    // Simple content moderation (in production, use AI service)
    const flaggedWords = ['scam', 'fake', 'stolen', 'broken', 'defect'];
    const suspiciousPatterns = [
      /\b\d{4}[-\s]\d{4}[-\s]\d{4}[-\s]\d{4}\b/, // Credit card pattern
      /\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b/, // Email pattern
      /\b\d{3}[-.\s]?\d{3}[-.\s]?\d{4}\b/, // Phone pattern
    ];

    const content = params.content.toLowerCase();
    const flaggedWordsFound = flaggedWords.filter(word => content.includes(word));
    const suspiciousPatternFound = suspiciousPatterns.some(pattern => pattern.test(params.content));

    const moderation = {
      flagged: flaggedWordsFound.length > 0 || suspiciousPatternFound,
      flagged_words: flaggedWordsFound,
      suspicious_patterns: suspiciousPatternFound,
      confidence: flaggedWordsFound.length > 0 ? 0.8 : suspiciousPatternFound ? 0.6 : 0.1,
      action_required: flaggedWordsFound.length > 0 ? 'review' : suspiciousPatternFound ? 'monitor' : 'none',
      content_type: params.content_type || 'unknown',
    };

    return {
      content: [
        {
          type: 'text',
          text: JSON.stringify(moderation, null, 2),
        },
      ],
    };
  }

  private async getUserInsights(params: { user_id?: string; metric?: string }) {
    if (!params.user_id) {
      throw new McpError(ErrorCode.InvalidParams, 'user_id is required');
    }

    const { data: profile, error: profileError } = await this.supabase
      .from('profiles')
      .select('*')
      .eq('id', params.user_id)
      .single();

    if (profileError) throw new McpError(ErrorCode.InternalError, profileError.message);

    const insights: any = {
      user_id: params.user_id,
      basic_info: {
        username: profile.username,
        verification_status: profile.verification_status,
        account_type: profile.account_type,
        member_since: profile.created_at,
      },
    };

    if (!params.metric || params.metric === 'activity') {
      const { data: listings } = await this.supabase
        .from('guitar_listings')
        .select('*')
        .eq('seller_id', params.user_id);

      insights.activity = {
        total_listings: listings?.length || 0,
        active_listings: listings?.filter(l => l.status === 'active').length || 0,
      };
    }

    if (!params.metric || params.metric === 'reputation') {
      insights.reputation = {
        seller_rating: profile.seller_rating,
        buyer_rating: profile.buyer_rating,
        total_sales: profile.total_sales,
        total_purchases: profile.total_purchases,
      };
    }

    return {
      content: [
        {
          type: 'text',
