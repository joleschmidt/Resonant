  // Utility methods
  private calculatePriceTrend(data: any[]): string {
    if (data.length < 2) return 'insufficient_data';
    
    const sortedByDate = data.sort((a, b) => 
      new Date(a.created_at).getTime() - new Date(b.created_at).getTime()
    );
    
    const firstHalf = sortedByDate.slice(0, Math.floor(sortedByDate.length / 2));
    const secondHalf = sortedByDate.slice(Math.floor(sortedByDate.length / 2));
    
    const firstAvg = firstHalf.reduce((sum, item) => sum + item.price, 0) / firstHalf.length;
    const secondAvg = secondHalf.reduce((sum, item) => sum + item.price, 0) / secondHalf.length;
    
    const change = ((secondAvg - firstAvg) / firstAvg) * 100;
    
    if (change > 5) return 'increasing';
    if (change < -5) return 'decreasing';
    return 'stable';
  }

  private getMostPopular(items: string[]): string {
    const counts = items.reduce((acc, item) => {
      acc[item] = (acc[item] || 0) + 1;
      return acc;
    }, {} as Record<string, number>);

    return Object.keys(counts).reduce((a, b) => 
      counts[a] > counts[b] ? a : b
    ) || 'unknown';
  }

  private getDistribution(items: string[]): Record<string, number> {
    return items.reduce((acc, item) => {
      acc[item] = (acc[item] || 0) + 1;
      return acc;
    }, {} as Record<string, number>);
  }

  private getPriceDistribution(prices: number[]): Record<string, number> {
    const ranges = {
      'under_500': 0,
      '500_1000': 0,
      '1000_2000': 0,
      '2000_5000': 0,
      'over_5000': 0,
    };

    prices.forEach(price => {
      if (price < 500) ranges['under_500']++;
      else if (price < 1000) ranges['500_1000']++;
      else if (price < 2000) ranges['1000_2000']++;
      else if (price < 5000) ranges['2000_5000']++;
      else ranges['over_5000']++;
    });

    return ranges;
  }

  private getMarketPosition(prices: number[]): string {
    const avg = prices.reduce((sum, price) => sum + price, 0) / prices.length;
    
    if (avg < 800) return 'budget_segment';
    if (avg < 2000) return 'mid_range';
    if (avg < 5000) return 'premium';
    return 'luxury';
  }

