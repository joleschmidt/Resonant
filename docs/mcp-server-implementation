### Main Server Implementation
```typescript
// src/index.ts
import { Server } from '@modelcontextprotocol/sdk/server/index.js';
import { StdioServerTransport } from '@modelcontextprotocol/sdk/server/stdio.js';
import {
  CallToolRequestSchema,
  ErrorCode,
  ListResourcesRequestSchema,
  ListToolsRequestSchema,
  McpError,
  ReadResourceRequestSchema,
  ListPromptsRequestSchema,
  GetPromptRequestSchema,
} from '@modelcontextprotocol/sdk/types.js';
import { createClient, SupabaseClient } from '@supabase/supabase-js';
import { z } from 'zod';
import dotenv from 'dotenv';

dotenv.config();

// Validation schemas
const SearchParamsSchema = z.object({
  query: z.string().optional(),
  brand: z.string().optional(),
  guitar_type: z.string().optional(),
  condition: z.string().optional(),
  price_min: z.number().optional(),
  price_max: z.number().optional(),
  location: z.string().optional(),
  limit: z.number().min(1).max(100).default(20),
});

const AnalysisParamsSchema = z.object({
  timeframe: z.enum(['24h', '7d', '30d', '90d']).default('30d'),
  category: z.string().optional(),
  brand: z.string().optional(),
});

const PriceAnalysisSchema = z.object({
  brand: z.string(),
  model: z.string().optional(),
  year: z.number().optional(),
  condition: z.string().optional(),
});

class GuitarMarketplaceMCPServer {
  private server: Server;
  private supabase: SupabaseClient;

  constructor() {
    this.server = new Server(
      {
        name: 'guitar-marketplace-server',
        version: '1.0.0',
      },
      {
        capabilities: {
          resources: {},
          tools: {},
          prompts: {},
        },
      }
    );

    this.supabase = createClient(
      process.env.SUPABASE_URL!,
      process.env.SUPABASE_SERVICE_ROLE_KEY!
    );

    this.setupHandlers();
  }

  private setupHandlers() {
    // Resource handlers
    this.server.setRequestHandler(ListResourcesRequestSchema, async () => {
      return {
        resources: [
          {
            uri: 'marketplace://listings/active',
            name: 'Active Guitar Listings',
            description: 'All currently active guitar listings on the platform',
            mimeType: 'application/json',
          },
          {
            uri: 'marketplace://analytics/dashboard',
            name: 'Marketplace Analytics',
            description: 'Key metrics and insights about the marketplace',
            mimeType: 'application/json',
          },
          {
            uri: 'marketplace://trends/guitars',
            name: 'Guitar Market Trends',
            description: 'Trending guitars, brands, and market insights',
            mimeType: 'application/json',
          },
          {
            uri: 'marketplace://users/statistics',
            name: 'User Statistics',
            description: 'Platform user statistics and engagement metrics',
            mimeType: 'application/json',
          },
          {
            uri: 'marketplace://security/alerts',
            name: 'Security Alerts',
            description: 'Recent security alerts and fraud detection reports',
            mimeType: 'application/json',
          },
        ],
      };
    });

    this.server.setRequestHandler(ReadResourceRequestSchema, async (request) => {
      const { uri } = request.params;

      switch (uri) {
        case 'marketplace://listings/active':
          return await this.getActiveListings();
        case 'marketplace://analytics/dashboard':
          return await this.getAnalyticsDashboard();
        case 'marketplace://trends/guitars':
          return await this.getGuitarTrends();
        case 'marketplace://users/statistics':
          return await this.getUserStatistics();
        case 'marketplace://security/alerts':
          return await this.getSecurityAlerts();
        default:
          throw new McpError(ErrorCode.InvalidRequest, `Unknown resource: ${uri}`);
      }
    });

    // Tool handlers
    this.server.setRequestHandler(ListToolsRequestSchema, async () => {
      return {
        tools: [
          {
            name: 'search_guitars',
            description: 'Search for guitars based on various criteria',
            inputSchema: {
              type: 'object',
              properties: {
                query: {
                  type: 'string',
                  description: 'Search query (brand, model, description)',
                },
                brand: {
                  type: 'string',
                  description: 'Filter by guitar brand',
                },
                guitar_type: {
                  type: 'string',
                  enum: ['electric', 'acoustic', 'classical', 'bass'],
                  description: 'Type of guitar',
                },
                condition: {
                  type: 'string',
                  enum: ['mint', 'excellent', 'very_good', 'good', 'fair', 'poor'],
                  description: 'Condition of the guitar',
                },
                price_min: {
                  type: 'number',
                  description: 'Minimum price in EUR',
                },
                price_max: {
                  type: 'number',
                  description: 'Maximum price in EUR',
                },
                location: {
                  type: 'string',
                  description: 'Location (city or region)',
                },
                limit: {
                  type: 'number',
                  minimum: 1,
                  maximum: 100,
                  default: 20,
                  description: 'Maximum number of results',
                },
              },
            },
          },
          {
            name: 'analyze_market_trends',
            description: 'Analyze market trends for guitars',
            inputSchema: {
              type: 'object',
              properties: {
                timeframe: {
                  type: 'string',
                  enum: ['24h', '7d', '30d', '90d'],
                  default: '30d',
                  description: 'Analysis timeframe',
                },
                category: {
                  type: 'string',
                  description: 'Guitar category to analyze',
                },
                brand: {
                  type: 'string',
                  description: 'Specific brand to analyze',
                },
