# JSON Schemas for AI & MCP Integration

## Core Entity Schemas

### User Profile Schema
```json
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.guitar-marketplace.de/schemas/user-profile.json",
  "title": "User Profile",
  "description": "Complete user profile schema for AI processing",
  "type": "object",
  "required": ["id", "username", "verification_status", "account_type"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique user identifier"
    },
    "username": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]{3,30}$",
      "description": "Unique username"
    },
    "full_name": {
      "type": ["string", "null"],
      "maxLength": 100,
      "description": "User's full name"
    },
    "email": {
      "type": "string",
      "format": "email",
      "description": "User's email address"
    },
    "avatar_url": {
      "type": ["string", "null"],
      "format": "uri",
      "description": "Profile picture URL"
    },
    "bio": {
      "type": ["string", "null"],
      "maxLength": 500,
      "description": "User biography"
    },
    "location": {
      "type": ["string", "null"],
      "maxLength": 100,
      "description": "User location"
    },
    "verification_status": {
      "type": "string",
      "enum": ["unverified", "email_verified", "phone_verified", "identity_verified", "fully_verified"],
      "description": "User verification level"
    },
    "account_type": {
      "type": "string",
      "enum": ["basic", "verified", "premium", "store", "admin"],
      "description": "Account type and permissions"
    },
    "seller_rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average seller rating"
    },
    "buyer_rating": {
      "type": "number",
      "minimum": 0,
      "maximum": 5,
      "multipleOf": 0.1,
      "description": "Average buyer rating"
    },
    "total_sales": {
      "type": "integer",
      "minimum": 0,
      "description": "Total completed sales"
    },
    "total_purchases": {
      "type": "integer",
      "minimum": 0,
      "description": "Total purchases made"
    },
    "preferences": {
      "type": "object",
      "properties": {
        "preferred_brands": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "User's preferred guitar brands"
        },
        "preferred_types": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["electric", "acoustic", "classical", "bass"]
          },
          "description": "User's preferred guitar types"
        },
        "price_range": {
          "type": "object",
          "properties": {
            "min": {
              "type": "number",
              "minimum": 0
            },
            "max": {
              "type": "number",
              "minimum": 0
            }
          },
          "description": "User's preferred price range"
        },
        "search_radius": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "description": "Preferred search radius in km"
        }
      },
      "description": "User preferences for personalization"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Account creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last profile update timestamp"
    },
    "last_active_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last activity timestamp"
    }
  },
  "additionalProperties": false,
  "x-ai-context": {
    "entity_type": "user",
    "privacy_level": "protected",
    "searchable_fields": ["username", "location", "bio"],
    "recommendation_fields": ["preferences", "seller_rating", "total_sales"],
    "analysis_fields": ["verification_status", "account_type", "created_at"]
  }
}
```

### Guitar Listing Schema
```json
{
