### Message Schema
```json
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.guitar-marketplace.de/schemas/message.json",
  "title": "Message",
  "description": "Message schema for conversations between users",
  "type": "object",
  "required": ["id", "conversation_id", "sender_id", "content", "message_type"],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique message identifier"
    },
    "conversation_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the conversation this message belongs to"
    },
    "sender_id": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the user who sent the message"
    },
    "content": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "description": "Message content"
    },
    "message_type": {
      "type": "string",
      "enum": ["text", "image", "offer", "system"],
      "description": "Type of message"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "maxItems": 5,
      "description": "Attached files or images"
    },
    "offer_details": {
      "type": ["object", "null"],
      "properties": {
        "amount": {
          "type": "number",
          "minimum": 0,
          "description": "Offer amount in EUR"
        },
        "expires_at": {
          "type": "string",
          "format": "date-time",
          "description": "When offer expires"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "accepted", "declined", "expired"],
          "description": "Offer status"
        }
      },
      "description": "Details for offer-type messages"
    },
    "read_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When message was read by recipient"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "When message was created"
    }
  },
  "additionalProperties": false,
  "x-ai-context": {
    "entity_type": "message",
    "privacy_level": "private",
    "searchable_fields": ["content"],
    "moderation_fields": ["content"],
    "analysis_fields": ["message_type", "created_at"]
  }
}
```

### Transaction Schema
```json
