    "brand": {
      "type": "string",
      "enum": [
        "Fender", "Gibson", "Martin", "Taylor", "Ibanez", "ESP", "Yamaha",
        "PRS", "Rickenbacker", "Gretsch", "Epiphone", "Squier", "Jackson",
        "Schecter", "Washburn", "Dean", "BC Rich", "Charvel", "Kramer", "Other"
