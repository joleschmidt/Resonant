        "pickup_configuration": {
          "type": ["string", "null"],
          "description": "Pickup layout (e.g., HSS, HH, SSS)"
        },
        "electronics": {
          "type": ["string", "null"],
          "description": "Electronic components and features"
        },
        "hardware": {
          "type": ["string", "null"],
          "description": "Hardware components (bridge, tuners, etc.)"
        },
        "finish": {
          "type": ["string", "null"],
          "description": "Guitar finish type and color"
        }
      },
      "description": "Detailed technical specifications"
